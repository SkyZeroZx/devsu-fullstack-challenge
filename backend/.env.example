POSTGRES_DB=devsu_banking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

JWT_SECRET=devsu-banking-secret-key-for-jwt-token-generation-2024-must-be-at-least-256-bits

# Admin seed credentials (used by the seed service)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache TTL
CACHE_TTL_CLIENTS=PT10M
CACHE_TTL_ACCOUNTS=PT10M
CACHE_TTL_TRANSACTIONS=PT5M
CACHE_TTL_LIST=PT2M

# Dev   (wipe + full sample data on every start):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build


# Staging (idempotent admin user only, data is preserved):
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml up --build


# Prod  (no seed service, no data changes):
#   docker compose up --build
