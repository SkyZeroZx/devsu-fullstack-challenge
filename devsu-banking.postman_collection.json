{
  "info": {
    "name": "Devsu Banking Challenge",
    "_postman_id": "devsu-banking-001",
    "description": "Coleccion para probar el API. El request de 'Login' automáticamente settea el token y precarga clientes, cuentas y movimientos en las variables, logrando que el resto de endpoints funcionen dinámicamente con la data disponible sin editarla manualmente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var isAuthRequest = pm.info.requestName === 'Login' || pm.info.requestName === 'Register (new user)';",
          "if (isAuthRequest) return;",
          "",
          "var token = pm.collectionVariables.get('token');",
          "if (!token) {",
          "    throw new Error(",
          "        '⛔ No authentication token found. Please run the \"Login\" request first. ' +",
          "        'The Login script will set the token AND pre-load dynamic IDs automatically.'",
          "    );",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "auth_service_url",
