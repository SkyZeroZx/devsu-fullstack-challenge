            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorro\",\n  \"saldoInicial\": 2000,\n  \"estado\": true,\n  \"clienteId\": \"cli-001\"\n}"
            }
          }
        },
        {
          "name": "Actualizar (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/cuentas/478758", "host": ["{{base_url}}"], "path": ["api", "cuentas", "478758"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorro\",\n  \"saldoInicial\": 2000,\n  \"estado\": false,\n  \"clienteId\": \"cli-001\"\n}"
            }
          }
        },
        {
          "name": "Actualizar parcial (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/cuentas/478758", "host": ["{{base_url}}"], "path": ["api", "cuentas", "478758"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": false\n}"
            }
          }
        },
        {
          "name": "Eliminar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/cuentas/478758", "host": ["{{base_url}}"], "path": ["api", "cuentas", "478758"] }
          }
        }
      ]
    },
    {
