{
  "info": {
    "name": "Devsu Banking Challenge",
    "_postman_id": "devsu-banking-001",
    "description": "Collection aligned with seed-dev.sql data.\n\nRun order: Login → Listar clientes (captures clienteId) → remaining requests.\n\nSeed data:\n- Admin: admin / admin123\n- Jose Lema (1234567890): cuentas 478758, 225487\n- Marianela Montalvo (0987654321): cuentas 495878, 496825",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",            "value": "http://localhost:8080", "type": "string" },
    { "key": "auth_service_url",    "value": "http://localhost:8091", "type": "string" },
    { "key": "banking_service_url", "value": "http://localhost:8090", "type": "string" },
    { "key": "token",               "value": "",                     "type": "string" },
    { "key": "clienteId_jose",      "value": "",                     "type": "string" },
    { "key": "clienteId_marianela", "value": "",                     "type": "string" },
    { "key": "last_movimiento_id",  "value": "",                     "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Register (new user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"test1234\"\n}"
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/validate?token={{token}}",
              "host": ["{{base_url}}"],
              "path": ["auth", "validate"],
              "query": [{ "key": "token", "value": "{{token}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Listar todos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "if (json.content && json.content.length > 0) {",
                  "    json.content.forEach(function(c) {",
                  "        if (c.nombre === 'Jose Lema') pm.collectionVariables.set('clienteId_jose', c.clienteId);",
                  "        if (c.nombre === 'Marianela Montalvo') pm.collectionVariables.set('clienteId_marianela', c.clienteId);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/clientes?page=0&size=20&sort=nombre,asc",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "nombre,asc" }
              ]
            }
          }
        },
        {
          "name": "Obtener Jose Lema",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/clientes/{{clienteId_jose}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes", "{{clienteId_jose}}"]
            }
          }
        },
        {
          "name": "Obtener Marianela Montalvo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/clientes/{{clienteId_marianela}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes", "{{clienteId_marianela}}"]
            }
          }
        },
        {
          "name": "Crear cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/clientes", "host": ["{{base_url}}"], "path": ["api", "clientes"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Osorio\",\n  \"genero\": \"Masculino\",\n  \"edad\": 28,\n  \"identificacion\": \"1122334455\",\n  \"direccion\": \"13 Junio y Equinoccial\",\n  \"telefono\": \"098874587\",\n  \"contrasena\": \"5678\",\n  \"estado\": true\n}"
            }
          }
        },
        {
          "name": "Actualizar Jose Lema (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/clientes/{{clienteId_jose}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes", "{{clienteId_jose}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Jose Lema\",\n  \"genero\": \"Masculino\",\n  \"edad\": 36,\n  \"identificacion\": \"1234567890\",\n  \"direccion\": \"Nueva direccion 123\",\n  \"telefono\": \"098254785\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
            }
          }
        },
        {
          "name": "Actualizar parcial Jose Lema (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/clientes/{{clienteId_jose}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes", "{{clienteId_jose}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"direccion\": \"Otavalo sn y principal\"\n}"
            }
          }
        },
        {
          "name": "Eliminar Marianela Montalvo",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/clientes/{{clienteId_marianela}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes", "{{clienteId_marianela}}"]
            }
          }
        }
      ]
    },
