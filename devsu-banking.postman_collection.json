            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorro\",\n  \"saldoInicial\": 2000,\n  \"estado\": false,\n  \"clienteId\": \"{{clienteId_jose}}\"\n}"
            }
          }
        },
        {
          "name": "Actualizar parcial cuenta 478758 (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/cuentas/478758",
              "host": ["{{base_url}}"],
              "path": ["api", "cuentas", "478758"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": true\n}"
            }
          }
        },
        {
