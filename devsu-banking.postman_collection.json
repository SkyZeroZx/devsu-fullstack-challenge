  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ── 1. Validate login itself ─────────────────────────────────",
                  "pm.test('Login exitoso (200)', function() { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Token recibido', function() { pm.expect(json.token).to.be.a('string').and.not.empty; });",
                  "if (!json.token) return;",
                  "",
                  "pm.collectionVariables.set('token', json.token);",
                  "",
                  "// ── 2. Fetch clientes and cuentas to setup dynamic variables ──",
                  "var baseUrl = pm.collectionVariables.get('base_url');",
                  "",
                  "// Fetch Clientes",
                  "pm.sendRequest({",
                  "    url: baseUrl + '/api/clientes?page=1&size=10',",
                  "    method: 'GET',",
                  "    header: { 'Authorization': 'Bearer ' + json.token }",
                  "}, function(err, res) {",
                  "    if (!err && res && res.code === 200) {",
                  "        var content = (res.json() || {}).content || [];",
                  "        if (content.length >= 1) pm.collectionVariables.set('clienteId_1', content[0].clienteId);",
                  "        if (content.length >= 2) pm.collectionVariables.set('clienteId_2', content[1].clienteId);",
                  "    }",
                  "});",
                  "",
                  "// Fetch Cuentas",
                  "pm.sendRequest({",
                  "    url: baseUrl + '/api/cuentas?page=1&size=10',",
                  "    method: 'GET',",
                  "    header: { 'Authorization': 'Bearer ' + json.token }",
                  "}, function(err, res) {",
                  "    if (!err && res && res.code === 200) {",
                  "        var content = (res.json() || {}).content || [];",
                  "        if (content.length >= 1) pm.collectionVariables.set('cuenta_1_numero', content[0].numeroCuenta);",
                  "        if (content.length >= 2) pm.collectionVariables.set('cuenta_2_numero', content[1].numeroCuenta);",
                  "        if (content.length >= 3) pm.collectionVariables.set('cuenta_3_numero', content[2].numeroCuenta);",
                  "        if (content.length >= 4) pm.collectionVariables.set('cuenta_4_numero', content[3].numeroCuenta);",
                  "    }",
                  "});",
                  "",
                  "// Fetch Movimientos",
                  "pm.sendRequest({",
                  "    url: baseUrl + '/api/movimientos?page=1&size=10',",
                  "    method: 'GET',",
                  "    header: { 'Authorization': 'Bearer ' + json.token }",
                  "}, function(err, res) {",
                  "    if (!err && res && res.code === 200) {",
                  "        var content = (res.json() || {}).content || [];",
                  "        if (content.length >= 1) pm.collectionVariables.set('last_movimiento_id', String(content[0].id));",
                  "    }",
                  "});"
                ]
              }
            }
          ],
