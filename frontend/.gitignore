# ============================================================
# Frontend .gitignore — Angular / Node.js / TypeScript
# ============================================================

# ---- Dependencies ----
node_modules/

# ---- Angular build output ----
dist/
.angular/
.angular/cache/

# ---- TypeScript compiled output ----
*.js.map
*.d.ts.map

# ---- Angular CLI cache ----
.angular/

# ---- Test coverage ----
coverage/
.nyc_output/

# ---- Environment files (use environment.ts templates instead) ----
src/environments/environment.local.ts

# ---- IDEs / Editors ----
.idea/
*.iml
.vscode/

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Lock files (keep one, ignore others) ----
# Uncomment the ones you DON'T use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ---- SonarQube ----
.sonar/
.scannerwork/

# ---- Storybook ----
storybook-static/

# ---- Cache ----
.cache/
.eslintcache
.stylelintcache
